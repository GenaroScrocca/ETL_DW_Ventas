                          name="Expression">(DT_I4)([YEAR]((DT_DATE)#{Package\Cargar Fact Ventas\Ventas.Outputs[Flat File Source Output].Columns[Fecha]}) * 10000 + [MONTH]((DT_DATE)#{Package\Cargar Fact Ventas\Ventas.Outputs[Flat File Source Output].Columns[Fecha]}) * 100 + [DAY]((DT_DATE)#{Package\Cargar Fact Ventas\Ventas.Outputs[Flat File Source Output].Columns[Fecha]}))</property>
